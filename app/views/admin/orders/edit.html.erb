<div class="flex items-center gap-3 mb-6">
  <%= link_to "← 返回", admin_order_path(@order), class: "btn btn-ghost btn-sm" %>
  <h1 class="text-2xl font-bold">編輯訂單 #<%= @order.id %></h1>
</div>

<div class="card bg-base-100 shadow border border-base-300 max-w-lg">
  <div class="card-body">
    <p class="text-sm opacity-60 mb-4">
      使用者：<strong><%= @order.user&.email %></strong>
    </p>

    <%= form_with model: [:admin, @order], class: "space-y-4" do |f| %>
      <% if @order.errors.any? %>
        <div class="alert alert-error text-sm">
          <ul class="list-disc list-inside">
            <% @order.errors.full_messages.each do |msg| %><li><%= msg %></li><% end %>
          </ul>
        </div>
      <% end %>

      <div class="form-control">
        <label class="label label-text font-medium">狀態</label>
        <%= f.select :status,
              Order.statuses.keys.map { |s| [s, s] },
              { selected: @order.status },
              class: "select select-bordered w-full" %>
      </div>

      <div class="form-control">
        <label class="label label-text font-medium">方案</label>
        <%= f.select :period,
              [["— 未設定 —", ""], ["monthly", "monthly"], ["yearly", "yearly"]],
              { selected: @order.period },
              class: "select select-bordered w-full" %>
      </div>

      <div class="form-control">
        <label class="label label-text font-medium">到期日</label>
        <%= f.datetime_local_field :expires_at,
              value: @order.expires_at&.strftime("%Y-%m-%dT%H:%M"),
              class: "input input-bordered w-full" %>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "儲存變更", class: "btn btn-primary" %>
        <%= link_to "取消", admin_order_path(@order), class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>
