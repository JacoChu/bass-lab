<div class="flex items-center gap-3 mb-6">
  <%= link_to "← 返回", admin_admin_users_path, class: "btn btn-ghost btn-sm" %>
  <h1 class="text-2xl font-bold">變更角色</h1>
</div>

<div class="card bg-base-100 shadow border border-base-300 max-w-sm">
  <div class="card-body">
    <p class="text-sm opacity-60 mb-4">
      Email：<strong><%= @user.email %></strong>
    </p>

    <%= form_with model: [:admin, @user], url: admin_admin_user_path(@user), class: "space-y-4" do |f| %>
      <div class="form-control">
        <label class="label label-text font-medium">角色</label>
        <%= f.select :role,
              User.roles.keys.map { |r| [r, r] },
              { selected: @user.role },
              class: "select select-bordered w-full" %>
      </div>

      <div class="flex gap-3 pt-2">
        <%= f.submit "儲存", class: "btn btn-primary" %>
        <%= link_to "取消", admin_admin_users_path, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>
</div>
