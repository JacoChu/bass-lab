<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">角色管理</h1>
</div>

<div class="card bg-base-100 shadow border border-base-300">
  <div class="overflow-x-auto">
    <table class="table table-zebra">
      <thead>
        <tr>
          <th>#</th>
          <th>Email</th>
          <th>顯示名稱</th>
          <th>角色</th>
          <th>建立時間</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td class="opacity-60"><%= user.id %></td>
            <td><%= user.email %></td>
            <td><%= user.display_name %></td>
            <td>
              <span class="badge <%= user.super_admin? ? 'badge-error' : 'badge-ghost' %>">
                <%= user.role %>
              </span>
            </td>
            <td class="opacity-60"><%= user.created_at.strftime("%Y-%m-%d") %></td>
            <td>
              <%= link_to "變更角色", edit_admin_admin_user_path(user), class: "btn btn-xs btn-outline" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
