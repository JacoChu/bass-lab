<%= form_with model: [:admin, user], class: "space-y-4" do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-error">
      <ul class="list-disc list-inside text-sm">
        <% user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if user.new_record? %>
    <div class="form-control">
      <%= f.label :email, "Email", class: "label label-text font-medium" %>
      <%= f.email_field :email, class: "input input-bordered w-full", placeholder: "user@example.com" %>
    </div>
  <% end %>

  <div class="form-control">
    <%= f.label :display_name, "顯示名稱", class: "label label-text font-medium" %>
    <%= f.text_field :display_name, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control">
    <%= f.label :role, "角色", class: "label label-text font-medium" %>
    <%= f.select :role, User.roles.keys.map { |r| [r, r] },
          { selected: user.role },
          class: "select select-bordered w-full" %>
  </div>

  <% if user.new_record? %>
    <div class="form-control">
      <%= f.label :password, "密碼", class: "label label-text font-medium" %>
      <%= f.password_field :password, class: "input input-bordered w-full" %>
    </div>

    <div class="form-control">
      <%= f.label :password_confirmation, "確認密碼", class: "label label-text font-medium" %>
      <%= f.password_field :password_confirmation, class: "input input-bordered w-full" %>
    </div>
  <% end %>

  <div class="flex gap-3 pt-2">
    <%= f.submit user.new_record? ? "建立使用者" : "儲存變更", class: "btn btn-primary" %>
    <%= link_to "取消", user.new_record? ? admin_users_path : admin_user_path(user), class: "btn btn-ghost" %>
  </div>
<% end %>
